def is_prime(n):
    # Numbers less than 2 are not prime
    if n < 2:
        return False

    for i in range(2, int(n**0.5) + 1):
        if n % i == 0:
            return False
    
    return True

num = int(input("Enter a number: "))

# Function call
if is_prime(num):
    print(f"{num} is a Prime Number")
else:
    print(f"{num} is Not a Prime Number")

#a Python program to analyze the input number is prime or not.
