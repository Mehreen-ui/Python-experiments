import tkinter as tk
from tkinter import ttk

# Conversion Functions
def convert():
    try:
        value = float(entry.get())
        choice = combo.get()

        if choice == "Rupees to Dollars":
            result = value / 83   # approx rate
        elif choice == "Celsius to Fahrenheit":
            result = (value * 9/5) + 32
        elif choice == "Inches to Feet":
            result = value / 12
        else:
            result = "Invalid"

        result_label.config(text=f"Result: {round(result, 2)}")

    except ValueError:
        result_label.config(text="Invalid input")


# GUI Window
root = tk.Tk()
root.title("Unit Converter")
root.geometry("350x250")

# Input Label
tk.Label(root, text="Enter Value:").pack(pady=5)

# Input Entry
entry = tk.Entry(root)
entry.pack(pady=5)

# Dropdown Menu
options = ["Rupees to Dollars", "Celsius to Fahrenheit", "Inches to Feet"]
combo = ttk.Combobox(root, values=options)
combo.set("Select Conversion")
combo.pack(pady=10)

# Convert Button
tk.Button(root, text="Convert", command=convert).pack(pady=10)

# Result Label
result_label = tk.Label(root, text="Result: ")
result_label.pack(pady=10)

# Run App
root.mainloop()
