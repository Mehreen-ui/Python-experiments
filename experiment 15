def calculate_average(numbers):
    total = 0
    count = 0
    
    for num in numbers:
        total += num
        count += 1
    
    average = total / count
    return average


# Intentional issues:
nums = [10, 20, '30', 40]   # '30' is string → error
avg = calculate_average(nums)
print("Average:", avg)
